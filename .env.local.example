# Supabase project settings — find these in Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Phase 3 — Google Maps/Places import
# Server-only secret (no NEXT_PUBLIC prefix — never exposed to the browser).
# See README.md "Setting up Google Maps import" for how to get this.
GOOGLE_MAPS_API_KEY=

# Follow-up email digest
# See README.md "Setting up the follow-up email digest" for how to get these.
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
DIGEST_FROM_EMAIL=Paragon Nexus <digest@yourdomain.com>
APP_URL=https://os.paragongl.com
CRON_SECRET=
